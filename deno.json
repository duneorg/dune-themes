{
  "workspace": ["./packages/theme-*", "./demos/*"],
  "tasks": {
    "scaffold": "deno run -A scripts/scaffold-themes.ts",
    "scaffold:html5up": "deno run -A scripts/scaffold-html5up-themes.ts",
    "graduate:html5up": "deno run -A scripts/graduate-html5up-themes.ts",
    "sync:manifests": "deno run -A scripts/sync-package-manifests.ts",
    "pack": "deno run -A scripts/pack-theme.ts",
    "pack:all": "deno run -A scripts/pack-theme.ts --all",
    "dry-run:all": "deno run -A scripts/dry-run-publish.ts --all",
    "demo": "deno run -A scripts/demo.ts",
    "demo:link": "deno run -A scripts/link-demo.ts",
    "demo:validate": "deno run -A scripts/demo-validate.ts",
    "screenshot": "deno run -A scripts/capture-screenshot.ts",
    "sha256": "deno run -A scripts/update-registry-sha256.ts",
    "release": "deno run -A scripts/release-theme.ts",
    "check": "deno check scripts/*.ts packages/theme-*/templates/*.tsx packages/theme-*/components/**/*.tsx"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@zip-js/zip-js": "jsr:@zip-js/zip-js@^2"
  },
  "compilerOptions": {
    "strict": true
  }
}
