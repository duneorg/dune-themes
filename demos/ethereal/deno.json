{
  "imports": {
    "preact": "npm:preact@^10",
    "preact/": "npm:preact@^10/",
    "preact/hooks": "npm:preact@^10/hooks",
    "preact/jsx-runtime": "npm:preact@^10/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10/jsx-dev-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@^6",
    "@dune/core": "jsr:@dune/core@^0.26"
  },
  "tasks": {
    "dev": "deno run -A --config=deno.json jsr:@dune/core@^0.26/cli dev --root . --port 8793",
    "validate": "deno run -A --config=deno.json jsr:@dune/core@^0.26/cli validate ."
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
